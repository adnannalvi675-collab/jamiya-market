      "url": "https://github.com/jameya-marketplace",
      "email": "team@jameya.io"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "tags": [
    {
      "name": "marketplace",
      "description": "Browse and discover Jameyas with personalized ranking"
    },
    {
      "name": "jameyas",
      "description": "Create and manage Jameya savings groups"
    },
    {
      "name": "seats",
      "description": "View and manage seats within Jameyas"
    },
    {
      "name": "reservations",
      "description": "Reserve seats with 2-phase confirmation flow"
    },
    {
      "name": "payments",
      "description": "Process payments and handle Stripe webhooks"
    },
    {
      "name": "users",
      "description": "User management, KYC verification, and risk profiling"
    }
  ],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development"
    },
    {
      "url": "https://jamiya-market-production.up.railway.app/",
      "description": "Production (placeholder)"
    }
  ],
  "components": {
    "schemas": {
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "email": {
            "type": "string",
            "example": "alice@example.com"
          },
          "name": {
            "type": "string",
            "example": "Alice Johnson"
          },
          "phone": {
            "type": "string",
            "example": "+1234567001"
          },
          "kycStatus": {
            "type": "string",
            "enum": [
              "PENDING",
              "VERIFIED",
              "REJECTED",
              "EXPIRED"
            ],
            "example": "VERIFIED"
          },
          "riskScore": {
            "type": "number",
            "example": 15,
            "description": "0-100 scale, lower = less risky"
          },
          "behaviorScore": {
            "type": "number",
            "example": 85,
            "description": "0-100 scale, higher = better"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-01-15T10:30:00.000Z"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "kycStatus",
          "riskScore",
          "behaviorScore",
          "createdAt"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 409
          },
          "error": {
            "type": "string",
            "example": "ConflictException"
          },
          "message": {
            "type": "string",
            "example": "Seat is not available. Current status: RESERVED"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-01-15T10:30:00.000Z"
          },
          "path": {
            "type": "string",
            "example": "/api/reservations"
          }
        },
        "required": [
          "statusCode",
          "error",
          "message",
          "timestamp",
          "path"
        ]
      },
      "UpdateKycDto": {
        "type": "object",
        "properties": {
          "kycStatus": {
            "type": "string",
            "enum": [
              "PENDING",
              "VERIFIED",
              "REJECTED",
              "EXPIRED"
            ]
          }
        },
        "required": [
          "kycStatus"
        ]
      },
      "KycEligibilityResponse": {
        "type": "object",
        "properties": {
          "eligible": {
            "type": "boolean",
            "example": true
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "VERIFIED",
              "REJECTED",
              "EXPIRED"
            ],
            "example": "VERIFIED"
          },
          "reason": {
            "type": "string",
            "example": "KYC verification is pending."
          }
        },
        "required": [
          "eligible",
          "status"
        ]
      },
      "MarketplaceJameyaResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "jameya-uuid-456"
          },
          "name": {
            "type": "string",
            "example": "Gold Savings Circle"
          },
          "monthlyContribution": {
            "type": "number",
            "example": 500
          },
          "duration": {
            "type": "number",
            "example": 12
          },
          "totalSeats": {
            "type": "number",
            "example": 12
          },
          "availableSeats": {
            "type": "number",
            "example": 4
          },
          "fillPercentage": {
            "type": "number",
            "example": 67
          },
          "score": {
            "type": "number",
            "example": 142.5,
            "description": "Ranking score"
          },
          "badges": {
            "example": [
              "Featured",
              "Only 4 seats left!"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "minJoiningPrice": {
            "type": "number",
            "example": 4200
          },
          "maxJoiningPrice": {
            "type": "number",
            "example": 6000
          }
        },
        "required": [
          "id",
          "name",
          "monthlyContribution",
          "duration",
          "totalSeats",
          "availableSeats",
          "fillPercentage",
          "score",
          "badges",
          "minJoiningPrice",
          "maxJoiningPrice"
        ]
      },
      "MarketplaceResponse": {
        "type": "object",
        "properties": {
          "jameyas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketplaceJameyaResponse"
            }
          },
          "total": {
            "type": "number",
            "example": 150
          },
          "page": {
            "type": "number",
            "example": 1
          },
          "limit": {
            "type": "number",
            "example": 20
          },
          "totalPages": {
            "type": "number",
            "example": 8
          }
        },
        "required": [
          "jameyas",
          "total",
          "page",
          "limit",
          "totalPages"
        ]
      },
      "SeatSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "seat-uuid-123"
          },
          "seatNumber": {
            "type": "number",
            "example": 1
          },
          "joiningPrice": {
            "type": "number",
            "example": 6000
          },
          "status": {
            "type": "string",
            "enum": [
              "AVAILABLE",
              "RESERVED",
              "CONFIRMED"
            ],
            "example": "AVAILABLE"
          }
        },
        "required": [
          "id",
          "seatNumber",
          "joiningPrice",
          "status"
        ]
      },
      "JameyaStatsResponse": {
        "type": "object",
        "properties": {
          "totalSeats": {
            "type": "number",
            "example": 12
          },
          "availableSeats": {
            "type": "number",
            "example": 4
          },
          "reservedSeats": {
            "type": "number",
            "example": 2
          },
          "confirmedSeats": {
            "type": "number",
            "example": 6
          },
          "fillPercentage": {
            "type": "number",
            "example": 67,
            "description": "Percentage of seats taken"
          }
        },
        "required": [
          "totalSeats",
          "availableSeats",
          "reservedSeats",
          "confirmedSeats",
          "fillPercentage"
        ]
      },
      "JameyaDetailResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "jameya-uuid-456"
          },
          "name": {
            "type": "string",
            "example": "Gold Savings Circle"
          },
          "description": {
            "type": "string",
            "example": "Premium savings group for verified members"
          },
          "monthlyContribution": {
            "type": "number",
            "example": 500
          },
          "duration": {
            "type": "number",
            "example": 12
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "ACTIVE",
              "FULL",
              "COMPLETED",
              "CANCELLED"
            ]
          },
          "seats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeatSummary"
            }
          },
          "stats": {
            "$ref": "#/components/schemas/JameyaStatsResponse"
          }
        },
        "required": [
          "id",
          "name",
          "monthlyContribution",
          "duration",
          "currency",
          "status",
          "seats",
          "stats"
        ]
      },
      "CreateReservationDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "User ID making the reservation"
          },
          "seatId": {
            "type": "string",
            "description": "Seat ID to reserve"
          },
          "idempotencyKey": {
            "type": "string",
            "description": "Client-generated idempotency key to prevent duplicate reservations",
            "example": "res_abc123_seat456"
          }
        },
        "required": [
          "userId",
          "seatId",
          "idempotencyKey"
        ]
      },
      "ReservationPaymentInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "payment-uuid-789"
          },
          "amount": {
            "type": "number",
            "example": 6000
          },
          "currency": {
            "type": "string",
            "example": "USD"
          },
          "stripeClientSecret": {
            "type": "string",
            "example": "pi_simulated_abc123_secret_xyz789",
            "description": "Stripe client secret for frontend"
          },
          "stripePaymentIntentId": {
            "type": "string",
            "example": "pi_simulated_abc123"
          }
        },
        "required": [
          "id",
          "amount",
          "currency",
          "stripeClientSecret",
          "stripePaymentIntentId"
        ]
      },
      "ReservationCreatedResponse": {
        "type": "object",
        "properties": {
          "reservation": {
            "type": "object",
            "description": "Reservation details",
            "example": {
              "id": "reservation-uuid-123",
              "seatId": "seat-uuid-456",
              "status": "PENDING",
              "expiresAt": "2026-01-15T10:33:00.000Z",
              "ttlSeconds": 180
            }
          },
          "payment": {
            "$ref": "#/components/schemas/ReservationPaymentInfo"
          }
        },
        "required": [
          "reservation",
          "payment"
        ]
      },
      "ReservationStatusResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "reservation-uuid-123"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "CONFIRMED",
              "EXPIRED",
              "CANCELLED"
            ]
          },
          "expiresAt": {
            "type": "string",
            "example": "2026-01-15T10:33:00.000Z"
          },
          "isExpired": {
            "type": "boolean",
            "example": false
          },
          "remainingSeconds": {
            "type": "number",
            "example": 145,
            "description": "Seconds remaining before expiry"
          }
        },
        "required": [
          "id",
          "status",
          "expiresAt",
          "isExpired",
          "remainingSeconds"
        ]
      },
      "SimulatePaymentDto": {
        "type": "object",
        "properties": {
          "paymentIntentId": {
            "type": "string",
            "example": "pi_simulated_abc123def456",
            "description": "PaymentIntent ID returned from the reservation step"
          },
          "success": {
            "type": "boolean",
            "example": true,
            "description": "true = payment succeeded, false = payment failed"
          }
        },
        "required": [
          "paymentIntentId",
          "success"
        ]
      },
      "WebhookResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failed",
              "already_processed",
              "unhandled"
            ]
          },
          "paymentId": {
            "type": "string",
            "example": "payment-uuid-789"
          },
          "reservationId": {
            "type": "string",
            "example": "reservation-uuid-123"
          },
          "reservation": {
            "type": "object",
            "description": "Reservation confirmation result",
            "example": {
              "status": "confirmed",
              "reservationId": "reservation-uuid-123"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    }
  }
}