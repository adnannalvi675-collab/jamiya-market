# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=Jameya Market Collab

# Database - Set on Railway
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# Redis - Set on Railway
REDIS_URL=redis://user:password@hostname:port
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USER=default
REDIS_DB=0

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRATION=3600

# Payment Service
PAYMENT_API_KEY=your-key
PAYMENT_API_SECRET=your-secret
PAYMENT_WEBHOOK_SECRET=your-secret

# Email Service (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# API Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs
